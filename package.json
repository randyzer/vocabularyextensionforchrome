{
  "name": "contextual-vocabulary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:e2e": "wxt build --mode test",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build:e2e && playwright test",
    "dict:build": "tsx scripts/dictionary/build.ts",
    "dict:check": "tsx scripts/dictionary/check.ts",
    "icons:build": "node scripts/generate-icons.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "idb": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "csv-parse": "latest",
    "fake-indexeddb": "latest",
    "happy-dom": "latest",
    "sharp": "latest",
    "tsx": "^4.22.4",
    "typescript": "latest",
    "vitest": "latest",
    "wxt": "latest"
  }
}
